---
import { siteLocales, type SiteLocale } from "../lib/load-site-data";
import type { SiteData } from "../lib/site-schema";

interface Props {
  locale: SiteLocale;
  site: SiteData;
}

const { locale, site } = Astro.props;

const ratingStars = [1, 2, 3, 4, 5];
const testimonialsAverage = (site.sections.testimonials.items.reduce((sum, item) => sum + item.rating, 0) / site.sections.testimonials.items.length).toFixed(1);
const testimonialsCount = site.sections.testimonials.items.length;
const localeLinks = siteLocales.map((entry) => ({
  code: entry,
  href: entry === "en" ? "/" : `/${entry}`,
  label: entry,
}));

function getTestimonialsReviewLabel(currentLocale: SiteLocale, count: number): string {
  if (currentLocale === "pt") {
    return `${count} avaliações`;
  }

  if (currentLocale === "es") {
    return `${count} reseñas`;
  }

  return `${count} reviews`;
}

function getTestimonialsSourceLabel(currentLocale: SiteLocale): string {
  if (currentLocale === "pt") {
    return "Powered by Google";
  }

  if (currentLocale === "es") {
    return "Powered by Google";
  }

  return "Powered by Google";
}

function isExternalLink(href: string): boolean {
  return href.startsWith("http://") || href.startsWith("https://");
}

function getSocialIcon(label: string) {
  const normalized = label.trim().toLowerCase();

  if (normalized.includes("facebook")) {
    return "facebook";
  }

  if (normalized.includes("instagram")) {
    return "instagram";
  }

  if (normalized.includes("linkedin")) {
    return "linkedin";
  }

  return null;
}
---

<header>
  <nav aria-label={site.header.navAriaLabel}>
    {site.header.navItems.map((item) => {
      const socialIcon = getSocialIcon(item.label);
      const external = isExternalLink(item.href);

      return (
        <a
          href={item.href}
          rel={external ? "noopener noreferrer nofollow" : undefined}
          target={external ? "_blank" : undefined}
        >
          {socialIcon === "facebook" && (
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <title>{item.label}</title>
              <path
                d="M12 2.04c-5.5 0-10 4.49-10 10.02c0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.89 3.78-3.89c1.09 0 2.23.19 2.23.19v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 0 0 8.44-9.9c0-5.53-4.5-10.02-10-10.02"
                fill="currentColor"
              />
            </svg>
          )}
          {socialIcon === "instagram" && (
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <title>{item.label}</title>
              <path
                d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4zm9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8A1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5a5 5 0 0 1-5 5a5 5 0 0 1-5-5a5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3a3 3 0 0 0 3 3a3 3 0 0 0 3-3a3 3 0 0 0-3-3"
                fill="currentColor"
              />
            </svg>
          )}
          {socialIcon === "linkedin" && (
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <title>{item.label}</title>
              <path
                d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"
                fill="currentColor"
              />
            </svg>
          )}
          {socialIcon === null && <span>{item.label}</span>}
        </a>
      );
    })}
  </nav>
  <p class="eyebrow">{site.header.eyebrow}</p>
  <h1>{site.title}</h1>
  <div class="language-switcher" aria-label="Language selector">
    {localeLinks.map((entry) => (
      <a
        class={entry.code === locale ? "is-active" : undefined}
        href={entry.href}
        hreflang={entry.code}
      >
        {entry.label}
      </a>
    ))}
  </div>
</header>

<main>
  <section class="testimonials-section" id={site.sections.testimonials.id}>
    <div class="testimonials-heading">
      <div class="testimonials-summary" aria-label={site.sections.testimonials.title}>
        <svg class="testimonials-google-mark" aria-hidden="true" viewBox="0 0 48 48">
          <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"></path>
          <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"></path>
          <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"></path>
          <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"></path>
        </svg>
        <span class="testimonials-summary-score">{testimonialsAverage}</span>
        <div class="testimonials-heading-stars" aria-hidden="true">
          {ratingStars.map((star) => (
            <svg class={star <= Math.round(Number(testimonialsAverage)) ? "is-active" : "is-inactive"} viewBox="0 -960 960 960">
              <path d="m233-120 65-281L80-590l288-25 112-265 112 265 288 25-218 189 65 281-247-149-247 149Z" />
            </svg>
          ))}
        </div>
        <span class="testimonials-summary-count">{getTestimonialsReviewLabel(locale, testimonialsCount)}</span>
      </div>
      <div class="testimonials-summary-source">{getTestimonialsSourceLabel(locale)}</div>
    </div>
    <div class="testimonials-grid">
      {site.sections.testimonials.items.map((item) => (
        <article class="testimonial-card" data-testimonial-card>
          <div class="testimonial-header">
            <h3>{item.headline}</h3>
            <div class="testimonial-rating" aria-label={`${item.rating} stars`}>
              <div class="testimonial-stars" aria-hidden="true">
                {ratingStars.map((star) => (
                  <svg class={star <= item.rating ? "is-active" : "is-inactive"} fill="currentColor" viewBox="0 -960 960 960">
                    <path d="m233-120 65-281L80-590l288-25 112-265 112 265 288 25-218 189 65 281-247-149-247 149Z" />
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <div class="testimonial-quote-wrap">
            <svg class="testimonial-quote-icon" aria-hidden="true" viewBox="0 -960 960 960">
              <path d="m228-240 92-160q-66 0-113-47t-47-113q0-66 47-113t113-47q66 0 113 47t47 113q0 23-5.5 42.5T458-480L320-240h-92Zm360 0 92-160q-66 0-113-47t-47-113q0-66 47-113t113-47q66 0 113 47t47 113q0 23-5.5 42.5T818-480L680-240h-92Z" />
            </svg>
            <p class="testimonial-quote">{item.quote}</p>
          </div>
          <div class="testimonial-author">
            <img alt={item.name} class="testimonial-avatar" height="48" loading="lazy" src={item.avatar} width="48" />
            <div class="testimonial-author-meta">
              <span class="testimonial-name">{item.name}</span>
              <span class="testimonial-role">
                <svg aria-hidden="true" viewBox="0 -960 960 960">
                  <path d="M160-440v-80h640v80H160Z" />
                </svg>
                <span>{item.role}</span>
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id={site.sections.mirror.id}>
    <div class="mirror-stack">
      <div class="mirror-intro">
        <h2>{site.sections.mirror.title}</h2>
      </div>
      <div class="section-split mirror-split">
        {site.sections.mirror.items && (
          <div>
            <h3 class="mirror-list-title">{site.sections.mirror.listTitle}</h3>
            <ul>
              {site.sections.mirror.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        )}
        <div class="mirror-side">
          <div class="mirror-card">
            <p>{site.sections.mirror.body}</p>
          </div>
          <div class="mirror-founder">
            <div class="mirror-founder-meta">
              <span class="mirror-founder-name">{site.sections.mirror.speaker.name}</span>
              <span class="mirror-founder-role">{site.sections.mirror.speaker.role}</span>
            </div>
            <img
              alt={site.sections.mirror.speaker.name}
              class="mirror-founder-avatar"
              height="96"
              loading="lazy"
              src={site.sections.mirror.speaker.avatar}
              width="96"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id={site.sections.diagnosis.id}>
    <div class="section-split diagnosis-split">
      <div aria-hidden="true"></div>
      <div class="section-copy">
        <h2>{site.sections.diagnosis.title}</h2>
        <p>{site.sections.diagnosis.body}</p>
        {site.sections.diagnosis.items && (
          <ul>
            {site.sections.diagnosis.items.map((item) => <li>{item}</li>)}
          </ul>
        )}
      </div>
    </div>
  </section>

  <section id={site.sections.howWorks.id}>
    <div class="section-split">
      <div class="section-copy">
        <h2>{site.sections.howWorks.title}</h2>
        <p>{site.sections.howWorks.body}</p>
        <a
          class="how-works-callout"
          href={site.sections.howWorks.callout.href}
          rel="noopener noreferrer"
          target="_blank"
        >
          <svg aria-hidden="true" viewBox="0 -960 960 960">
            <path d="M200-40q-33 0-56.5-23.5T120-120v-40h720v40q0 33-23.5 56.5T760-40H200Zm-40-200q-33 0-56.5-23.5T80-320v-320q0-33 23.5-56.5T160-720h640q33 0 56.5 23.5T880-640v320q0 33-23.5 56.5T800-240H160Zm-40-560v-40q0-33 23.5-56.5T200-920h560q33 0 56.5 23.5T840-840v40H120Zm280 440 200-120-200-120v240Z" />
          </svg>
          <span>{site.sections.howWorks.callout.title}</span>
        </a>
      </div>
      <div class="how-works-steps">
        {site.sections.howWorks.items.map((item, index) => (
          <article class="how-works-step">
            <div class="how-works-step-icon" aria-hidden="true">
              {index === 0 && (
                <svg viewBox="0 -960 960 960">
                  <path d="M40-120v-80h880v80H40Zm120-120q-33 0-56.5-23.5T80-320v-440q0-33 23.5-56.5T160-840h640q33 0 56.5 23.5T880-760v440q0 33-23.5 56.5T800-240H160Zm280-140h80v-167l64 63 56-56-160-160-160 160 56 57 64-64v167Z" />
                </svg>
              )}
              {index === 1 && (
                <svg viewBox="0 -960 960 960">
                  <path d="M160-120v-170l527-526q12-12 27-18t30-6q16 0 30.5 6t25.5 18l56 56q12 11 18 25.5t6 30.5q0 15-6 30t-18 27L330-120H160Zm586-529 54-54-57-57-54 54 57 57ZM560-120q74 0 137-37t63-103q0-36-19-62t-51-45l-59 59q23 10 36 22t13 26q0 23-36.5 41.5T560-200q-17 0-28.5 11.5T520-160q0 17 11.5 28.5T560-120ZM183-426l60-60q-20-8-31.5-16.5T200-520q0-12 18-24t76-37q88-38 117-69t29-70q0-55-44-87.5T280-840q-45 0-80.5 16T145-785q-11 13-9 29t15 26q13 11 29 9t27-13q14-14 31-20t42-6q41 0 60.5 12t19.5 28q0 14-17.5 25.5T262-654q-80 35-111 63.5T120-520q0 32 17 54.5t46 39.5Z" />
                </svg>
              )}
              {index === 2 && (
                <svg viewBox="0 -960 960 960">
                  <path d="M360-270h160q33 0 56.5-23.5T600-350v-50q0-33-23.5-56.5T520-480h-80v-50h160v-80H360v210h160v50H360v80Zm0-570v-80h240v80H360Zm-19.5 731.5Q275-137 226-186t-77.5-114.5Q120-366 120-440t28.5-139.5Q177-645 226-694t114.5-77.5Q406-800 480-800q62 0 119 20t107 58l56-56 56 56-56 56q38 50 58 107t20 119q0 74-28.5 139.5T734-186q-49 49-114.5 77.5T480-80q-74 0-139.5-28.5Z" />
                </svg>
              )}
            </div>
            <div class="how-works-step-copy">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id={site.sections.deliverables.id}>
    <div class="section-split">
      <div class="section-copy">
        <h2>{site.sections.deliverables.title}</h2>
        <p>{site.sections.deliverables.body}</p>
        <article class="deliverables-callout">
          <svg aria-hidden="true" viewBox="0 -960 960 960">
            <path d="M360-520q-34 0-57-23t-23-57v-200q0-33 23-56.5t57-23.5h240v360H360Zm320 0v-360h120q33 0 56.5 23.5T880-800v200q0 34-23.5 57T800-520H680ZM320-120v-320h272q14 0 24 8t14 19q4 11 1.5 23T618-369l-59 49H400v60h180l162-134q22-16 46.5-20t48.5 2q24 6 45.5 20.5T919-354L684-157q-22 18-48 27.5t-54 9.5H320ZM120-80q-17 0-28.5-11.5T80-120v-280q0-17 11.5-28.5T120-440h120v320q0 17-11.5 28.5T200-80h-80Z" />
          </svg>
          <div class="deliverables-callout-copy">
            <strong>{site.sections.deliverables.callout.title}</strong>
            <span>{site.sections.deliverables.callout.body}</span>
          </div>
        </article>
      </div>
      {site.sections.deliverables.items && (
        <ul>
          {site.sections.deliverables.items.map((item) => <li>{item}</li>)}
        </ul>
      )}
    </div>
  </section>

  <section id={site.sections.icp.id}>
    <div class="section-split diagnosis-split">
      <figure class="icp-figure">
        <img
          alt={site.sections.icp.figure.alt}
          height="536"
          loading="lazy"
          src={site.sections.icp.figure.src}
          width="439"
        />
      </figure>
      <div class="section-copy">
        <h2>{site.sections.icp.title}</h2>
        <p>{site.sections.icp.body}</p>
        {site.sections.icp.items && (
          <ul>
            {site.sections.icp.items.map((item) => <li>{item}</li>)}
          </ul>
        )}
      </div>
    </div>
  </section>

  <section id={site.sections.anchorVal.id}>
    <div class="section-split">
      <div class="anchor-val-title-card">
        <h2>{site.sections.anchorVal.title}</h2>
      </div>
      <div class="section-copy">
        <p>{site.sections.anchorVal.body}</p>
        {site.sections.anchorVal.items && (
          <ul>
            {site.sections.anchorVal.items.map((item) => <li>{item}</li>)}
          </ul>
        )}
      </div>
    </div>
  </section>

  <section id={site.sections.priceBuy.id}>
    <div class="section-split">
      <div class="section-copy">
        <h2>{site.sections.priceBuy.title}</h2>
        <div class="price-buy-row">
          <div class="price-buy-value" aria-label={`${site.sections.priceBuy.pricing.currency} ${site.sections.priceBuy.pricing.amount} ${site.sections.priceBuy.pricing.period}`}>
            <span class="price-buy-currency">{site.sections.priceBuy.pricing.currency}</span>
            <span class="price-buy-amount">{site.sections.priceBuy.pricing.amount}</span>
            <span class="price-buy-period">{site.sections.priceBuy.pricing.period}</span>
          </div>
          <div class="price-buy-mark-wrap">
            <svg class="price-buy-mark" aria-hidden="true" viewBox="0 0 50 50">
              <path d="M 25 0.0390625 C 22.84 0.0390625 20.799531 0.88015625 19.269531 2.4101562 L 9.6796875 12 L 12.929688 12 C 14.529687 12 16.039922 12.619766 17.169922 13.759766 L 23.939453 20.529297 C 24.519453 21.109297 25.480547 21.109531 26.060547 20.519531 L 32.830078 13.759766 C 33.960078 12.619766 35.470312 12 37.070312 12 L 40.320312 12 L 30.730469 2.4101562 C 29.200469 0.88015625 27.16 0.0390625 25 0.0390625 z M 7.6796875 14 L 2.4101562 19.269531 C -0.74984375 22.429531 -0.74984375 27.570469 2.4101562 30.730469 L 7.6796875 36 L 12.929688 36 C 13.999687 36 14.999766 35.580078 15.759766 34.830078 L 22.529297 28.060547 C 23.889297 26.700547 26.110703 26.700547 27.470703 28.060547 L 34.240234 34.830078 C 35.000234 35.580078 36.000312 36 37.070312 36 L 42.320312 36 L 47.589844 30.730469 C 50.749844 27.570469 50.749844 22.429531 47.589844 19.269531 L 42.320312 14 L 37.070312 14 C 36.000313 14 35.000234 14.419922 34.240234 15.169922 L 27.470703 21.939453 C 26.790703 22.619453 25.9 22.960938 25 22.960938 C 24.1 22.960937 23.209297 22.619453 22.529297 21.939453 L 15.759766 15.169922 C 14.999766 14.419922 13.999688 14 12.929688 14 L 7.6796875 14 z M 25 29.037109 C 24.615 29.038359 24.229453 29.185469 23.939453 29.480469 L 17.169922 36.240234 C 16.039922 37.380234 14.529687 38 12.929688 38 L 9.6796875 38 L 19.269531 47.589844 C 20.799531 49.119844 22.84 49.960938 25 49.960938 C 27.16 49.960938 29.200469 49.119844 30.730469 47.589844 L 40.320312 38 L 37.070312 38 C 35.470313 38 33.960078 37.380234 32.830078 36.240234 L 26.060547 29.470703 C 25.770547 29.180703 25.385 29.035859 25 29.037109 z"></path>
            </svg>
            <span>{site.sections.priceBuy.markLabel}</span>
          </div>
        </div>
      </div>
      <div class="price-buy-actions">
        {site.sections.priceBuy.items && (
          <>
            <h3 class="price-buy-list-title">
              <span>{site.sections.priceBuy.listTitle}</span>
              <svg aria-hidden="true" viewBox="0 -960 960 960">
                <path d="m344-60-76-128-144-32 14-148-98-112 98-112-14-148 144-32 76-128 136 58 136-58 76 128 144 32-14 148 98 112-98 112 14 148-144 32-76 128-136-58-136 58Zm94-278 226-226-56-58-170 170-86-84-56 56 142 142Z" />
              </svg>
            </h3>
            <ul>
              {site.sections.priceBuy.items.map((item) => <li>{item}</li>)}
            </ul>
          </>
        )}
        <a class="price-buy-button" href={site.sections.priceBuy.cta.href}>
          <span>{site.sections.priceBuy.cta.label}</span>
          <svg aria-hidden="true" viewBox="0 -960 960 960">
            <path d="M223.5-103.5Q200-127 200-160t23.5-56.5Q247-240 280-240t56.5 23.5Q360-193 360-160t-23.5 56.5Q313-80 280-80t-56.5-23.5Zm400 0Q600-127 600-160t23.5-56.5Q647-240 680-240t56.5 23.5Q760-193 760-160t-23.5 56.5Q713-80 680-80t-56.5-23.5ZM208-800h590q23 0 35 20.5t1 41.5L692-482q-11 20-29.5 31T622-440H324l-44 80h480v80H280q-45 0-68-39.5t-2-78.5l54-98-144-304H40v-80h130l38 80Z" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="inverse-section" id={site.sections.costInaction.id}>
    <div class="section-split">
      <div class="section-copy">
        <div class="cost-inaction-heading">
          <svg aria-hidden="true" viewBox="0 -960 960 960">
            <path d="M640-240v-80h104L536-526 376-366 80-664l56-56 240 240 160-160 264 264v-104h80v240H640Z" />
          </svg>
          <h2>{site.sections.costInaction.title}</h2>
        </div>
      </div>
      <div class="cost-inaction-copy">
        <h3>{site.sections.costInaction.bodyTitle}</h3>
        <p>{site.sections.costInaction.body}</p>
      </div>
    </div>
  </section>

  <section id={site.sections.creator.id} itemscope itemtype="https://schema.org/Organization">
    <div class="creator-stack">
      <div class="section-copy">
        <meta content={site.sections.creator.entity.name} itemprop="name" />
        <meta content={site.sections.creator.entity.description} itemprop="description" />
