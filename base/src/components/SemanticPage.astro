<script is:inline>
  const mirrorCheckboxes = Array.from(document.querySelectorAll('.mirror-checkbox'));
  const mirrorResultValue = document.getElementById('mirror-result-value');
  const mirrorResultScore = document.getElementById('mirror-result-score');

  if (mirrorCheckboxes.length > 0 && mirrorResultValue && mirrorResultScore) {
    const updateMirrorResult = () => {
      const checkedCount = mirrorCheckboxes.filter((input) => input.checked).length;
      const score = 70 + checkedCount * 10;
      mirrorResultValue.textContent = String(score);
      mirrorResultValue.classList.remove('is-warning', 'is-success', 'is-highlight');
      mirrorResultScore.classList.remove('is-warning', 'is-success', 'is-highlight');

      if (score === 70) {
        mirrorResultValue.classList.add('is-warning');
        mirrorResultScore.classList.add('is-warning');
        return;
      }

      if (score >= 110) {
        mirrorResultValue.classList.add('is-highlight');
        mirrorResultScore.classList.add('is-highlight');
        return;
      }

      mirrorResultValue.classList.add('is-success');
      mirrorResultScore.classList.add('is-success');
    };

    mirrorCheckboxes.forEach((input) => {
      input.addEventListener('change', updateMirrorResult);
    });

    updateMirrorResult();
  }
</script>

