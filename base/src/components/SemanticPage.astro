---
import type { SiteData } from "../lib/site-schema";

interface Props {
  site: SiteData;
}

const { site } = Astro.props;
---

<header>
  <nav aria-label={site.header.navAriaLabel}>
    {site.header.navItems.map((item) => <a href={item.href} target="_blank" rel="nofollow">{item.label}</a>)}
  </nav>
  <p>{site.header.eyebrow}</p>
  <h1>{site.title}</h1>
</header>

<main>
  <section id={site.sections.testimonials.id}>
    <h2>{site.sections.testimonials.title}</h2>
    {site.sections.testimonials.articles.map((article) => (
      <article>
        <h3>{article.title}</h3>
        <p>{article.body}</p>
      </article>
    ))}
  </section>

  <section id={site.sections.mirror.id}>
    <h2>{site.sections.mirror.title}</h2>
    <p>{site.sections.mirror.body}</p>
  </section>

  <section id={site.sections.diagnosis.id}>
    <h2>{site.sections.diagnosis.title}</h2>
    <p>{site.sections.diagnosis.body}</p>
  </section>

  <section id={site.sections.howWorks.id}>
    <h2>{site.sections.howWorks.title}</h2>
    <p>{site.sections.howWorks.body}</p>
  </section>

  <section id={site.sections.deliverables.id}>
    <h2>{site.sections.deliverables.title}</h2>
    <p>{site.sections.deliverables.body}</p>
  </section>

  <section id={site.sections.icp.id}>
    <h2>{site.sections.icp.title}</h2>
    <p>{site.sections.icp.body}</p>
  </section>

  <section id={site.sections.anchorVal.id}>
    <h2>{site.sections.anchorVal.title}</h2>
    <p>{site.sections.anchorVal.body}</p>
  </section>

  <section id={site.sections.priceBuy.id}>
    <h2>{site.sections.priceBuy.title}</h2>
    <p>{site.sections.priceBuy.body}</p>
  </section>

  <section id={site.sections.costInaction.id}>
    <h2>{site.sections.costInaction.title}</h2>
    <p>{site.sections.costInaction.body}</p>
  </section>

  <section id={site.sections.creator.id}>
    <h2>{site.sections.creator.title}</h2>
    <p>{site.sections.creator.body}</p>
  </section>

  <section id={site.sections.faqCta.id}>
    <h2>{site.sections.faqCta.title}</h2>
    <p>{site.sections.faqCta.body}</p>
  </section>

  <section id={site.sections.contact.id}>
    <h2>{site.sections.contact.title}</h2>
    <address>
      {site.sections.contact.lines.map((line) => (
        <>
          {line}
          <br />
        </>
      ))}
    </address>
  </section>
</main>

<footer>
  <p>{site.footer.text}</p>
</footer>

<style>
  header {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  nav a {
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(255, 253, 250, 0.84);
    text-decoration: none;
    color: var(--color-text-soft);
    transition: border-color 140ms ease, color 140ms ease, transform 140ms ease;
  }

  nav a:hover,
  nav a:focus-visible {
    color: var(--color-accent-strong);
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  header p {
    margin-bottom: var(--space-xs);
    color: var(--color-accent-strong);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-heading);
    line-height: 1.1;
  }

  h1 {
    max-width: 12ch;
    font-size: clamp(2.5rem, 7vw, 5.75rem);
    text-wrap: balance;
  }

  main {
    padding-bottom: var(--space-2xl);
  }

  section {
    margin-bottom: var(--space-lg);
    padding: var(--space-lg);
    border: 1px solid rgba(217, 201, 178, 0.7);
    border-radius: var(--radius-lg);
    background: rgba(255, 253, 250, 0.88);
    box-shadow: var(--shadow-soft);
  }

  section > p,
  address {
    max-width: var(--reading-width);
    color: var(--color-text-soft);
  }

  h2 {
    margin-bottom: var(--space-sm);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
  }

  article + article {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  h3 {
    margin-bottom: var(--space-2xs);
    font-size: 1.15rem;
  }

  address {
    font-style: normal;
  }

  footer {
    padding: 0 0 var(--space-xl);
    color: var(--color-text-soft);
  }

  @media (min-width: 48rem) {
    header {
      padding-top: var(--space-xl);
    }

    section {
      padding: var(--space-xl);
    }
  }
</style>
