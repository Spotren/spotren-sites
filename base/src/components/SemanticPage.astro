---
import { siteLocales, type SiteLocale } from "../lib/load-site-data";
import { sanitizeRichText as rich } from "../lib/sanitize-rich-text";
import type { SiteData } from "../lib/site-schema";
import WhatsAppIcon from "./WhatsAppIcon.astro";

interface Props {
  locale: SiteLocale;
  site: SiteData;
}

const { locale, site } = Astro.props;

const ratingStars = [1, 2, 3, 4, 5];
const testimonialsAverage = (site.sections.testimonials.items.reduce((sum, item) => sum + item.rating, 0) / site.sections.testimonials.items.length).toFixed(1);
const testimonialsCount = site.sections.testimonials.reviewCount;
const mirrorItems = site.sections.mirror.items ?? [];
const localeLinks = siteLocales.map((entry) => ({
  code: entry,
  href: entry === "en" ? "/" : `/${entry}`,
  label: entry,
}));

function getTestimonialsReviewLabel(currentLocale: SiteLocale, count: number): string {
  if (currentLocale === "pt") {
    return `${count} reviews`;
  }

  if (currentLocale === "es") {
    return `${count} reseñas`;
  }

  return `${count} reviews`;
}

function getTestimonialsSourceLabel(currentLocale: SiteLocale): string {
  if (currentLocale === "pt") {
    return "Powered by Google";
  }

  if (currentLocale === "es") {
    return "Powered by Google";
  }

  return "Powered by Google";
}

function isExternalLink(href: string): boolean {
  return href.startsWith("http://") || href.startsWith("https://");
}

function getSocialIcon(label: string) {
  const normalized = label.trim().toLowerCase();

  if (normalized.includes("facebook")) {
    return "facebook";
  }

  if (normalized.includes("instagram")) {
    return "instagram";
  }

  if (normalized.includes("linkedin")) {
    return "linkedin";
  }

  return null;
}
---

<header>
  <nav aria-label={site.header.navAriaLabel}>
    {site.header.navItems.map((item) => {
      const socialIcon = getSocialIcon(item.label);
      const external = isExternalLink(item.href);

      return (
        <a
          href={item.href}
          rel={external ? "noopener noreferrer nofollow" : undefined}
          target={external ? "_blank" : undefined}
        >
          {socialIcon === "facebook" && (
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <title>{item.label}</title>
              <path
                d="M12 2.04c-5.5 0-10 4.49-10 10.02c0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.89 3.78-3.89c1.09 0 2.23.19 2.23.19v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 0 0 8.44-9.9c0-5.53-4.5-10.02-10-10.02"
                fill="currentColor"
              />
            </svg>
          )}
          {socialIcon === "instagram" && (
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <title>{item.label}</title>
              <path
                d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4zm9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8A1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5a5 5 0 0 1-5 5a5 5 0 0 1-5-5a5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3a3 3 0 0 0 3 3a3 3 0 0 0 3-3a3 3 0 0 0-3-3"
                fill="currentColor"
              />
            </svg>
          )}
          {socialIcon === "linkedin" && (
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <title>{item.label}</title>
              <path
                d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"
                fill="currentColor"
              />
            </svg>
          )}
          {socialIcon === null && <span>{item.label}</span>}
        </a>
      );
    })}
  </nav>
  <h1>{site.title}</h1>
  <div class="offer">
    <div class="offer-column">
      <article class="deliverables-callout offer-callout">
        <svg aria-hidden="true" viewBox="0 -960 960 960">
          <path d="m520-120 40-280H319l321-440h40l-40 280h241L560-120h-40ZM120-240v-80h348l-12 80H120ZM80-440v-80h228l-58 80H80Zm80-200v-80h294l-58 80H160Z" />
        </svg>
        <div class="deliverables-callout-copy">
          <strong>{site.header.offer.title}</strong>
          <span set:html={rich(site.header.offer.body)} />
        </div>
      </article>
    </div>
    <div class="offer-column" aria-hidden="true"></div>
    <div class="offer-column offer-price">
      <div class="price-buy-value" aria-label={`${site.header.offer.price.currency} ${site.header.offer.price.amount}`}>
        <span class="offer-price-currency">{site.header.offer.price.currency}</span>
        <span class="offer-price-amount">{site.header.offer.price.amount}</span>
        <span class="offer-price-period">{site.header.offer.price.period}</span>
      </div>
    </div>
  </div>
  <div class="language-switcher" aria-label="Language selector">
    {localeLinks.map((entry) => (
      <a
        class={entry.code === locale ? "is-active" : undefined}
        href={entry.href}
        hreflang={entry.code}
      >
        {entry.label}
      </a>
    ))}
  </div>
</header>

<main>
  <section class="testimonials-section" id={site.sections.testimonials.id}>
    <div class="testimonials-heading">
      <div class="testimonials-summary" aria-label={site.sections.testimonials.title}>
        <svg class="testimonials-google-mark" aria-hidden="true" viewBox="0 0 48 48">
          <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"></path>
          <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"></path>
          <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"></path>
          <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"></path>
        </svg>
        <span class="testimonials-summary-score">{testimonialsAverage}</span>
        <div class="testimonials-heading-stars" aria-hidden="true">
          {ratingStars.map((star) => (
            <svg class={star <= Math.round(Number(testimonialsAverage)) ? "is-active" : "is-inactive"} viewBox="0 -960 960 960">
              <path d="m233-120 65-281L80-590l288-25 112-265 112 265 288 25-218 189 65 281-247-149-247 149Z" />
            </svg>
          ))}
        </div>
        <span class="testimonials-summary-count">{getTestimonialsReviewLabel(locale, testimonialsCount)}</span>
      </div>
      <div class="testimonials-summary-source">{getTestimonialsSourceLabel(locale)}</div>
    </div>
    <div class="testimonials-grid">
      {site.sections.testimonials.items.map((item) => (
        <article class="testimonial-card" data-testimonial-card>
          <div class="testimonial-header">
            <h3>{item.headline}</h3>
            <div class="testimonial-rating" aria-label={`${item.rating} stars`}>
              <div class="testimonial-stars" aria-hidden="true">
                {ratingStars.map((star) => (
                  <svg class={star <= item.rating ? "is-active" : "is-inactive"} fill="currentColor" viewBox="0 -960 960 960">
                    <path d="m233-120 65-281L80-590l288-25 112-265 112 265 288 25-218 189 65 281-247-149-247 149Z" />
                  </svg>
                ))}
              </div>
            </div>
          </div>
          <div class="testimonial-quote-wrap">
            <svg class="testimonial-quote-icon" aria-hidden="true" viewBox="0 -960 960 960">
              <path d="m228-240 92-160q-66 0-113-47t-47-113q0-66 47-113t113-47q66 0 113 47t47 113q0 23-5.5 42.5T458-480L320-240h-92Zm360 0 92-160q-66 0-113-47t-47-113q0-66 47-113t113-47q66 0 113 47t47 113q0 23-5.5 42.5T818-480L680-240h-92Z" />
            </svg>
            <p class="testimonial-quote" set:html={rich(item.quote)} />
          </div>
          <div class="testimonial-author">
            <img alt={item.name} class="testimonial-avatar" height="48" loading="lazy" src={item.avatar} width="48" />
            <div class="testimonial-author-meta">
              <span class="testimonial-name">{item.name}</span>
              <span class="testimonial-role">
                <svg aria-hidden="true" viewBox="0 -960 960 960">
                  <path d="M160-440v-80h640v80H160Z" />
                </svg>
                <span>{item.role}</span>
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id={site.sections.mirror.id}>
    <div class="mirror-stack">
      <div class="mirror-intro">
        <h2>{site.sections.mirror.title}</h2>
      </div>
      <div class="section-split mirror-split">
        {mirrorItems.length > 0 && (
          <div>
            <h3 class="mirror-list-title">{site.sections.mirror.listTitle}</h3>
            <ul>
              {mirrorItems.map((item, index) => (
                <li class="mirror-check-item">
                  <input
                    class="mirror-checkbox"
                    checked={index >= mirrorItems.length - 3}
                    id={`mirror-check-${index}`}
                    name="mirror-needs"
                    type="checkbox"
                    value={String(index)}
                  />
                  <label class="mirror-check-label" for={`mirror-check-${index}`}>
                    <span class="rich-inline" set:html={rich(item)} />
                  </label>
                </li>
              ))}
            </ul>
          </div>
        )}
        <div class="mirror-result-card">
          <div class="mirror-result-title">Match</div>
          <div class="mirror-result-score" id="mirror-result-score">
            <svg class="mirror-result-mark" xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" aria-hidden="true">
              <path d="m233-120 65-281L80-590l288-25 112-265 112 265 288 25-218 189 65 281-247-149-247 149Z" />
            </svg>
            <div class="mirror-result-value" id="mirror-result-value">{site.sections.mirror.result.value}</div>
            <svg class="mirror-result-mark" xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" aria-hidden="true">
              <path d="m233-120 65-281L80-590l288-25 112-265 112 265 288 25-218 189 65 281-247-149-247 149Z" />
            </svg>
          </div>
          <p set:html={rich(site.sections.mirror.result.body)} />
        </div>
      </div>
    </div>
  </section>

  <section id={site.sections.diagnosis.id}>
    <div class="section-split diagnosis-split">
      <div class="section-copy">
        <h2>{site.sections.diagnosis.title}</h2>
        <p set:html={rich(site.sections.diagnosis.body)} />
        {site.sections.diagnosis.items && (
          <ul>
            {site.sections.diagnosis.items.map((item) => <li><span class="rich-inline" set:html={rich(item)} /></li>)}
          </ul>
        )}
        <p set:html={rich(site.sections.diagnosis.afterList)} />
      </div>
      <div class="diagnosis-side">
        <div class="diagnosis-opportunity">
          <h3>{site.sections.diagnosis.opportunity.title}</h3>
          {site.sections.diagnosis.opportunity.paragraphs.map((paragraph) => (
            <p set:html={rich(paragraph)} />
          ))}
        </div>
        <div class="diagnosis-note">
          <p set:html={rich(site.sections.mirror.body)} />
        </div>
        <div class="diagnosis-speaker">
          <div class="diagnosis-speaker-meta">
            <span class="diagnosis-speaker-name">{site.sections.mirror.speaker.name}</span>
            <span class="diagnosis-speaker-role">{site.sections.mirror.speaker.role}</span>
          </div>
          <img
            alt={site.sections.mirror.speaker.name}
            class="diagnosis-speaker-avatar"
            height="96"
            loading="lazy"
            src={site.sections.mirror.speaker.avatar}
            width="96"
          />
        </div>
      </div>
    </div>
  </section>

  <section id={site.sections.howWorks.id}>
    <div class="section-split">
      <div class="section-copy">
        <h2>{site.sections.howWorks.title}</h2>
        <p set:html={rich(site.sections.howWorks.body)} />
      </div>
      <div class="how-works-steps">
        {site.sections.howWorks.items.map((item, index) => (
          <article class="how-works-step">
            <div class="how-works-step-icon" aria-hidden="true">
              {index === 0 && (
                <WhatsAppIcon class="is-compact" />
              )}
              {index === 1 && (
                <svg viewBox="0 -960 960 960">
                  <path d="m159-168-34-14q-31-13-41.5-45t3.5-63l72-156v278Zm160 88q-33 0-56.5-23.5T239-160v-240l106 294q3 7 6 13.5t8 12.5h-40Zm206-4q-32 12-62-3t-42-47L243-622q-12-32 2-62.5t46-41.5l302-110q32-12 62 3t42 47l178 488q12 32-2 62.5T827-194L525-84Zm-57.5-487.5Q479-583 479-600t-11.5-28.5Q456-640 439-640t-28.5 11.5Q399-617 399-600t11.5 28.5Q422-560 439-560t28.5-11.5ZM497-160l302-110-178-490-302 110 178 490ZM319-650l302-110-302 110Z" />
                </svg>
              )}
              {index === 2 && (
                <svg viewBox="0 -960 960 960">
                  <path d="M360-840v-80h240v80H360Zm80 440h80v-240h-80v240Zm-99.5 291.5Q275-137 226-186t-77.5-114.5Q120-366 120-440t28.5-139.5Q177-645 226-694t114.5-77.5Q406-800 480-800q62 0 119 20t107 58l56-56 56 56-56 56q38 50 58 107t20 119q0 74-28.5 139.5T734-186q-49 49-114.5 77.5T480-80q-74 0-139.5-28.5ZM678-242q82-82 82-198t-82-198q-82-82-198-82t-198 82q-82 82-82 198t82 198q82 82 198 82t198-82ZM480-440Z" />
                </svg>
              )}
            </div>
            <div class="how-works-step-copy">
              <h3>{item.title}</h3>
              <p set:html={rich(item.body)} />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id={site.sections.deliverables.id}>
    <div class="section-split">
      <div class="section-copy">
        <h2>{site.sections.deliverables.title}</h2>
        <p set:html={rich(site.sections.deliverables.body)} />
        <article class="deliverables-callout">
          <svg aria-hidden="true" viewBox="0 -960 960 960">
            <path d="M360-520q-34 0-57-23t-23-57v-200q0-33 23-56.5t57-23.5h240v360H360Zm320 0v-360h120q33 0 56.5 23.5T880-800v200q0 34-23.5 57T800-520H680ZM320-120v-320h272q14 0 24 8t14 19q4 11 1.5 23T618-369l-59 49H400v60h180l162-134q22-16 46.5-20t48.5 2q24 6 45.5 20.5T919-354L684-157q-22 18-48 27.5t-54 9.5H320ZM120-80q-17 0-28.5-11.5T80-120v-280q0-17 11.5-28.5T120-440h120v320q0 17-11.5 28.5T200-80h-80Z" />
          </svg>
          <div class="deliverables-callout-copy">
            <strong>{site.sections.deliverables.callout.title}</strong>
            <span set:html={rich(site.sections.deliverables.callout.body)} />
          </div>
        </article>
      </div>
      {site.sections.deliverables.items && (
        <ul>
          {site.sections.deliverables.items.map((item) => <li><span class="rich-inline" set:html={rich(item)} /></li>)}
        </ul>
      )}
    </div>
  </section>

  <section id={site.sections.icp.id}>
    <div class="icp-stack">
      <div class="section-copy">
        <h2>{site.sections.icp.title}</h2>
        <p set:html={rich(site.sections.icp.body)} />
        {site.sections.icp.items && (
          <ul class="icp-grid">
            {site.sections.icp.items.map((item) => (
              <li class:list={item.className}>
                {item.className === "aesthetic-clinics" && (
                  <svg aria-hidden="true" class="icp-item-icon" viewBox="0 -960 960 960">
                    <path d="M496-346 346-496l332-332q12-12 28.5-12t28.5 12l93 93q12 12 12 28.5T828-678L496-346Zm0-114 248-247-37-37-247 248 36 36Zm-56 340 80-80h360v80H440Zm-237 0q-46 0-88.5-18T40-188l265-264 104 104q14 14 22 32t8 38q0 20-8 38.5T409-207l-19 19q-32 32-74.5 50T227-120h-24Zm0-80h24q30 0 58-11.5t49-32.5l19-19q6-6 6-14t-6-14l-48-48-136 135q8 2 17 3t17 1Zm541-507-37-37 37 37ZM305-339Z" />
                  </svg>
                )}
                {item.className === "dental-practices" && (
                  <svg aria-hidden="true" class="icp-item-icon" viewBox="0 -960 960 960">
                    <path d="M200-80v-360h80v-184L144-760l160-160 56 56-104 104 104 104v216h80v360H200Zm320 0v-360h80v-125q-52-14-86-56t-34-99q0-66 47-113t113-47q66 0 113 47t47 113q0 57-34 99t-86 56v125h80v360H520Zm120-560q33 0 56.5-23.5T720-720q0-33-23.5-56.5T640-800q-33 0-56.5 23.5T560-720q0 33 23.5 56.5T640-640ZM280-160h80v-200h-80v200Zm320 0h80v-200h-80v200Zm-320 0h80-80Zm320 0h80-80Z" />
                  </svg>
                )}
                {item.className === "law-firms" && (
                  <svg aria-hidden="true" class="icp-item-icon" viewBox="0 -960 960 960">
                    <path d="M160-120v-80h480v80H160Zm226-194L160-540l84-86 228 226-86 86Zm254-254L414-796l86-84 226 226-86 86Zm184 408L302-682l56-56 522 522-56 56Z" />
                  </svg>
                )}
                {item.className === "accounting-offices" && (
                  <svg aria-hidden="true" class="icp-item-icon" viewBox="0 -960 960 960">
                    <path d="m720-80-56-56 63-64H480v-80h247l-63-64 56-56 160 160L720-80ZM80-440v-120h120v120H80Zm201-41q-41-41-41-99v-160q0-58 41-99t99-41q58 0 99 41t41 99v160q0 58-41 99t-99 41q-58 0-99-41Zm360 0q-41-41-41-99v-160q0-58 41-99t99-41q58 0 99 41t41 99v160q0 58-41 99t-99 41q-58 0-99-41Zm-218.5-56.5Q440-555 440-580v-160q0-25-17.5-42.5T380-800q-25 0-42.5 17.5T320-740v160q0 25 17.5 42.5T380-520q25 0 42.5-17.5Zm360 0Q800-555 800-580v-160q0-25-17.5-42.5T740-800q-25 0-42.5 17.5T680-740v160q0 25 17.5 42.5T740-520q25 0 42.5-17.5Z" />
                  </svg>
                )}
                {item.className === "auto-shops" && (
                  <svg aria-hidden="true" class="icp-item-icon" viewBox="0 -960 960 960">
                    <path d="M240-200v40q0 17-11.5 28.5T200-120h-40q-17 0-28.5-11.5T120-160v-320l84-240q6-18 21.5-29t34.5-11h440q19 0 34.5 11t21.5 29l84 240v320q0 17-11.5 28.5T800-120h-40q-17 0-28.5-11.5T720-160v-40H240Zm-8-360h496l-42-120H274l-42 120Zm-32 80v200-200Zm100 160q25 0 42.5-17.5T360-380q0-25-17.5-42.5T300-440q-25 0-42.5 17.5T240-380q0 25 17.5 42.5T300-320Zm360 0q25 0 42.5-17.5T720-380q0-25-17.5-42.5T660-440q-25 0-42.5 17.5T600-380q0 25 17.5 42.5T660-320Zm-460 40h560v-200H200v200Z" />
                  </svg>
                )}
                {item.className === "home-services" && (
                  <svg aria-hidden="true" class="icp-item-icon" viewBox="0 -960 960 960">
                    <path d="M440-80q-33 0-56.5-23.5T360-160v-160H240q-33 0-56.5-23.5T160-400v-280q0-66 47-113t113-47h480v440q0 33-23.5 56.5T720-320H600v160q0 33-23.5 56.5T520-80h-80ZM240-560h480v-200h-40v160h-80v-160h-40v80h-80v-80H320q-33 0-56.5 23.5T240-680v120Zm0 160h480v-80H240v80Zm0 0v-80 80Z" />
                  </svg>
                )}
                {item.className === "real-estate" && (
