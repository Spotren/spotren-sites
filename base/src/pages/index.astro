---
import SemanticPage from "../components/SemanticPage.astro";
import { loadSiteData } from "../lib/load-site-data";
import BaseLayout from "../layouts/BaseLayout.astro";

const locale = "en";
const site = loadSiteData(locale);
---

<BaseLayout
  description={site.description}
  faviconContentType={site.faviconContentType}
  faviconHref={site.faviconHref}
  locale={locale}
  seoTitle={site.seoTitle}
>
  <SemanticPage locale={locale} site={site} />
</BaseLayout>
