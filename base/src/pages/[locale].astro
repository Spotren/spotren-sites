---
import SemanticPage from "../components/SemanticPage.astro";
import { loadSiteData, siteLocales, type SiteLocale } from "../lib/load-site-data";
import BaseLayout from "../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return siteLocales.map((locale) => ({
    params: { locale },
  }));
}

const locale = Astro.params.locale as SiteLocale;
const site = loadSiteData(locale);
---

<BaseLayout
  description={site.description}
  faviconContentType={site.faviconContentType}
  faviconHref={site.faviconHref}
  locale={locale}
  seoTitle={site.seoTitle}
  site={site}
>
  <SemanticPage locale={locale} site={site} />
</BaseLayout>
