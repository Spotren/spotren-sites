---
import { loadSiteData, siteLocales, type SiteLocale } from "../lib/load-site-data";

export function getStaticPaths() {
  return siteLocales.map((locale) => ({
    params: { locale },
  }));
}

const locale = Astro.params.locale as SiteLocale;
const site = loadSiteData(locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <title>{site.title}</title>
    <link href={site.faviconHref ?? "/favicon.ico"} rel="icon" type={site.faviconContentType ?? "image/x-icon"} />
  </head>
  <body>
    <main>
      <h1>{site.title}</h1>
    </main>
  </body>
</html>
