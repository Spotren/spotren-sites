---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WhatsAppIcon from "../../components/WhatsAppIcon.astro";
import { loadSiteData } from "../../lib/load-site-data";
import { sanitizeRichText as rich } from "../../lib/sanitize-rich-text";

const locale = "en";
const site = loadSiteData(locale);
const successPage = site.successPage;

if (!successPage) {
  throw new Error("Missing successPage content for en locale.");
}
---

<BaseLayout
  description={site.description}
  faviconContentType={site.faviconContentType}
  faviconHref={site.faviconHref}
  locale={locale}
  seoTitle={successPage.title}
  site={site}
>
  <main class="success-page">
    <article class="success-card">
      <img
        alt={successPage.image.alt}
        class="success-image"
        height="320"
        loading="eager"
        src={successPage.image.src}
        width="320"
      />
      <h1>{successPage.title}</h1>
      <p set:html={rich(successPage.body)} />
      <a class="success-button" href={successPage.button.href}>
        <span>{successPage.button.label}</span>
        <WhatsAppIcon />
      </a>
    </article>
  </main>
</BaseLayout>

<style>
  .success-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: var(--space-xl) var(--space-md);
  }

  .success-card {
    width: min(100%, 42rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: rgba(255, 253, 250, 0.82);
    text-align: center;
    box-shadow: var(--shadow-soft);
  }

  .success-image {
    width: min(100%, 14rem);
    height: auto;
  }

  .success-card > h1 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.05;
  }

  .success-card > p {
    margin: 0;
    max-width: 42ch;
    color: var(--color-text-soft);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
  }

  .success-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    gap: 0.7rem;
    padding: 0.75rem 1.7rem;
    border-radius: 999px;
    background: #25d366;
    color: white;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
  }

  .success-button > svg {
    width: 1.35rem;
    height: 1.35rem;
    fill: currentColor;
  }

  .success-button:hover {
    background: color-mix(in srgb, #25d366 88%, black);
  }
</style>
